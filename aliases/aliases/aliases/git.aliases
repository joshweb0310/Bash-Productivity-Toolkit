# --- Git basics ---
alias gs='git status'
alias ga='git add .'
alias gc='git commit -m'
alias gp='git push'
alias gl='git pull'
alias gb='git branch'
alias gco='git checkout'

# --- Git advanced ---
alias gundo='git reset --soft HEAD~1'
alias gclean='git clean -fd'
alias gdiff='git diff'
alias glog='git log --oneline --graph --decorate'
